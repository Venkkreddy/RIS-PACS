APP_ENV_MODE=local
NODE_ENV=development
PORT=8081
ENABLE_AUTH=true
BACKEND_URL=http://localhost:8081
FRONTEND_URL=http://localhost:5173
OHIF_BASE_URL=http://localhost:3000
OHIF_PUBLIC_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_ALL=true
DEFAULT_DEV_ROLE=admin
MASTER_ADMIN_EMAILS=metupalle@gmail.com,praveenk1006@gmail.com,gunapiano24@gmail.com
SESSION_SECRET=change-me-to-a-real-secret-32ch
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret

# Firebase configuration
FIREBASE_PROJECT_ID=ris-pacs-9859a
GCP_PROJECT_ID=ris-pacs-9859a
GCS_BUCKET=ris-pacs-9859a.firebasestorage.app

SENDGRID_API_KEY=your-sendgrid-key
SENDGRID_FROM_EMAIL=reports@example.com
DICOOGLE_BASE_URL=http://localhost:8080
# Optional secondary Dicoogle URL (leave empty when not needed)
DICOOGLE_FALLBACK_BASE_URL=
DICOOGLE_STORAGE_DIR=./storage
TENANT_STORAGE_ROOT=./storage
# Keep this as Dicoogle's internal path (inside its container)
DICOOGLE_INDEX_URI=file:///var/dicoogle/storage
MEDASR_SERVER_URL=http://localhost:5001
MEDASR_ENABLED=false

# Multi-tenant configuration (Firebase Firestore)
JWT_SECRET=change-me-to-a-real-jwt-secret-at-least-32-chars
MULTI_TENANT_ENABLED=true
PLATFORM_ADMIN_KEY=change-me-platform-admin-key

# ─── HIPAA Compliance Configuration ───
HIPAA_AUDIT_ENABLED=true
HIPAA_AUDIT_RETENTION_DAYS=2190
HIPAA_SESSION_TIMEOUT_MINUTES=15
HIPAA_MAX_FAILED_LOGINS=5
HIPAA_LOCKOUT_DURATION_MINUTES=30
HIPAA_REQUIRE_HTTPS=true
HIPAA_MIN_PASSWORD_LENGTH=12
